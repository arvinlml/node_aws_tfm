{
  "name": "node-aws-tfm",
  "version": "1.0.0",
  "description": "A comprehensive Node.js AWS module with Terraform support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "package": "node scripts/package.mjs",
    "publish": "node scripts/publish.mjs",
    "test": "npm run build && node tests/simple-runner.js || jest",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts,.js",
    "lint:fix": "eslint src tests --ext .ts,.js --fix",
    "type-check": "tsc --noEmit",
    "compile": "tsc",
    "start": "node dist/index.js",
    "test:allure": "npm run build && jest --reporters=default --reporters=jest-allure",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:clean": "rm -rf allure-results allure-report"
  },
  "keywords": [
    "aws",
    "terraform",
    "s3",
    "dynamodb",
    "step-functions",
    "sns",
    "ses",
    "eventbridge"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.420.0",
    "@aws-sdk/client-eventbridge": "^3.420.0",
    "@aws-sdk/client-s3": "^3.420.0",
    "@aws-sdk/client-ses": "^3.420.0",
    "@aws-sdk/client-sfn": "^3.420.0",
    "@aws-sdk/client-sns": "^3.420.0",
    "@aws-sdk/util-dynamodb": "^3.420.0",
    "archiver": "^7.0.1",
    "aws-lambda": "^1.0.7",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "allure-commandline": "^2.38.1",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-allure": "^0.1.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
